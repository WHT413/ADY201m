# The administrative username for MinIO.
# Common default: admin
MINIO_ROOT_USER=admin

# The administrative password.
# ⚠️ CRITICAL: Must be at least 8 characters long, otherwise the container will fail to start.
MINIO_ROOT_PASSWORD=change_me_12345678

# The endpoint URL to access MinIO.
# - Use 'minio:9000' if running inside Docker (service name).
# - Use 'localhost:9000' if running scripts from your host machine.
MINIO_ENDPOINT=minio:9000

# Your personal API Key from the Riot Developer Portal.
# Get it here: https://developer.riotgames.com/
# Format example: RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
RIOT_API_KEY=RGAPI_YOUR_KEY_HERE
